# RFID integration test configuration
# Copy to .env and fill in your values

# RFID reader serial port (required for hardware tests)
RFID_PORT=/dev/ttyUSB0

# Koha intranet URL (default: https://ffzg.koha-dev.rot13.org:8443/cgi-bin/koha/mainpage.pl)
KOHA_URL=https://ffzg.koha-dev.rot13.org:8443/cgi-bin/koha/mainpage.pl

# Circulation page URL (default: https://ffzg.koha-dev.rot13.org:8443/cgi-bin/koha/circ/circulation.pl)
CIRCULATION_URL=https://ffzg.koha-dev.rot13.org:8443/cgi-bin/koha/circ/circulation.pl

# Koha intranet credentials
KOHA_USER=your_koha_username
KOHA_PASS=your_koha_password

# Chrome DevTools port (default: 9333)
CDP_PORT=9333

# RFID server port (default: 9000, must match koha-rfid.js hardcode)
RFID_SERVER_PORT=9000
